---
import { buildTimestamp } from "./build.js";
import ComponentTimebox from "./Timebox.astro";
const buildTimestampYear = buildTimestamp.getUTCFullYear();
const copyrightYearsString: string = `2026${buildTimestampYear === 2026 ? "" : `~${buildTimestampYear}`}`;
---

<footer class="footer">
	<hr />
	<p>
		©️ {copyrightYearsString}
		<a rel="external" href="https://github.com/hugoalh">hugoalh</a>
	</p>
	<p>🕰️ <ComponentTimebox timestamp={buildTimestamp} /></p>
	<noscript>
		<p>
			💡 JavaScript is disabled; Enable JavaScript for a better
			experience.
		</p>
	</noscript>
	<p>🚧 DistBoard is in development.</p>
	<p>
		🧑‍💻 Help to improve DistBoard on <a
			rel="external"
			href="https://github.com/hugoalh/distboard">GitHub</a
		>!
	</p>
	<p>
		🏗️ Build with <a rel="external" href="https://astro.build">Astro</a> and ❤️.
	</p>
</footer>
