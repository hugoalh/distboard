---
import "../styles/main.scss";
interface Props {
	ogLang?: string;
	title?: string;
}
const { ogLang = "en_US", title = "" } = Astro.props;
const titleFmt: string = `${title.length > 0 ? `${title} | ` : ""}DistBoard @hugoalh`;
---

<head>
	<meta charset="utf-8" />
	<meta name="color-scheme" content="light dark" />
	<meta
		name="viewport"
		content="width=device-width, initial-scale=1.0, interactive-widget=resizes-content"
	/>
	<meta name="generator" content={Astro.generator} />
	<meta name="robots" content="index, follow" />
	<meta property="og:title" content={titleFmt} />
	<meta property="og:type" content="website" />
	<meta property="og:locale" content={ogLang} />
	<meta property="og:site_name" content="DistBoard @hugoalh" />
	<meta property="twitter:title" content={titleFmt} />
	<slot />
	<title>{titleFmt}</title>
</head>
